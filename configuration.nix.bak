{ config, lib, pkgs, ... }:

{
  imports =
    [ # Подключаем сгенерированный файл с описанием железа и дисков
      ./hardware-configuration.nix
    ];


  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;
  nix.settings.experimental-features = [ "nix-command" "flakes" ];
  
  boot.supportedFilesystems = [ "btrfs" ];


  networking.hostName = "nixlensk323";


  networking.networkmanager.enable = false;
  networking.useDHCP = false;

  # Настраиваем интерфейс ens18
  networking.interfaces.ens18 = {
    ipv4.addresses = [ {
      address = "45.13.237.210";
      prefixLength = 24;
    } ];
    ipv6.addresses = [ {
      address = "2a0e:97c0:711:9c::1";
      prefixLength = 64;
    } ];
  };


  networking.defaultGateway = "45.13.237.1";
  networking.defaultGateway6 = {
    address = "fe80::1";
    interface = "ens18";
  };


  networking.nameservers = [ "1.1.1.1" ];


  time.timeZone = "Europe/Moscow";
  i18n.defaultLocale = "en_US.UTF-8";
  console = {
    font = "Lat2-Terminus16";
    keyMap = "us";
  };


  users.users.zumuvik = {
    isNormalUser = true;
    extraGroups = [ "wheel" ]; # Дает права sudo
  };


  environment.systemPackages = with pkgs; [
    neovim     
    wget
    git        
    curl
    btop       
    tree
    btrfs-progs 
  ];


  services.openssh = {
    enable = true;
    settings = {
      
      PermitRootLogin = "yes"; 
      PasswordAuthentication = true;
    };
  };

  networking.firewall.allowedTCPPorts = [ 22 ];

  
  system.stateVersion = "25.11"; 
}
